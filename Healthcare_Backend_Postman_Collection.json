{
  "info": {
    "name": "Healthcare Backend APIs",
    "description": "Postman collection for the Healthcare Backend System API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.token) {",
                  "    pm.collectionVariables.set(\"token\", jsonData.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Patients",
      "item": [
        {
          "name": "Create Patient",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"age\": 35,\n  \"gender\": \"Male\",\n  \"contact\": \"1234567890\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/patients",
              "host": ["{{baseUrl}}"],
              "path": ["patients"]
            }
          }
        },
        {
          "name": "Get User's Patients",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/patients",
              "host": ["{{baseUrl}}"],
              "path": ["patients"]
            }
          }
        },
        {
          "name": "Get Specific Patient",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/patients/:id",
              "host": ["{{baseUrl}}"],
              "path": ["patients", ":id"],
              "variable": [
                { "key": "id", "value": "PATIENT_ID_HERE" }
              ]
            }
          }
        },
        {
          "name": "Update Patient",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"contact\": \"9876543210\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/patients/:id",
              "host": ["{{baseUrl}}"],
              "path": ["patients", ":id"],
              "variable": [
                { "key": "id", "value": "PATIENT_ID_HERE" }
              ]
            }
          }
        },
        {
          "name": "Delete Patient",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/patients/:id",
              "host": ["{{baseUrl}}"],
              "path": ["patients", ":id"],
              "variable": [
                { "key": "id", "value": "PATIENT_ID_HERE" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Doctors",
      "item": [
        {
          "name": "Create Doctor",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Dr. Smith\",\n  \"specialization\": \"Cardiology\",\n  \"contact\": \"555-0101\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/doctors",
              "host": ["{{baseUrl}}"],
              "path": ["doctors"]
            }
          }
        },
        {
          "name": "Get All Doctors",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/doctors",
              "host": ["{{baseUrl}}"],
              "path": ["doctors"]
            }
          }
        },
        {
          "name": "Get Specific Doctor",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/doctors/:id",
              "host": ["{{baseUrl}}"],
              "path": ["doctors", ":id"],
              "variable": [
                { "key": "id", "value": "DOCTOR_ID_HERE" }
              ]
            }
          }
        },
        {
          "name": "Update Doctor",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"specialization\": \"Neurology\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/doctors/:id",
              "host": ["{{baseUrl}}"],
              "path": ["doctors", ":id"],
              "variable": [
                { "key": "id", "value": "DOCTOR_ID_HERE" }
              ]
            }
          }
        },
        {
          "name": "Delete Doctor",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/doctors/:id",
              "host": ["{{baseUrl}}"],
              "path": ["doctors", ":id"],
              "variable": [
                { "key": "id", "value": "DOCTOR_ID_HERE" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Mappings (Patient-Doctor)",
      "item": [
        {
          "name": "Assign Doctor to Patient",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientId\": \"PATIENT_ID_HERE\",\n  \"doctorId\": \"DOCTOR_ID_HERE\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/mappings",
              "host": ["{{baseUrl}}"],
              "path": ["mappings"]
            }
          }
        },
        {
          "name": "Get All Mappings",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/mappings",
              "host": ["{{baseUrl}}"],
              "path": ["mappings"]
            }
          }
        },
        {
          "name": "Get Doctors by Patient",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/mappings/:patientId",
              "host": ["{{baseUrl}}"],
              "path": ["mappings", ":patientId"],
              "variable": [
                { "key": "patientId", "value": "PATIENT_ID_HERE" }
              ]
            }
          }
        },
        {
          "name": "Remove Mapping",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/mappings/:id",
              "host": ["{{baseUrl}}"],
              "path": ["mappings", ":id"],
              "variable": [
                { "key": "id", "value": "MAPPING_ID_HERE" }
              ]
            }
          }
        }
      ]
    }
  ]
}
